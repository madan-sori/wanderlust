<% layout("/layouts/boilerplate") %>

<div class="row  mt-3">
    <h2 class="col-6 offset-3">SignUp on Wanderlust</h2>
     <div class="col-6 offset-3">
        <form action="/signup" method="POST" novalidate class="needs-validation">
             <div class="mb-3">
            <label for="username" class="from-label">Username :</label>
            <input 
                type="text" 
                name="username"
                id="username" 
                placeholder="enter title"
                class="form-control"
                required
            >
             <div class="valid-feedback">  Looks good</div>

        </div>
                  <div class="mb-3">
            <label for="email" class="from-label">Email :</label>
            <input 
                type="email" 
                name="email"
                id="email" 
                placeholder="enter email"
                class="form-control"
                required
            >
             <div class="valid-feedback">  Looks good</div>
        </div>
               <div class="mb-3">
            <label for="password" class="from-label">Password :</label>
            <input 
                type="password" 
                name="password"
                id="password" 
                placeholder="enter password"
                class="form-control"
                required
            >

             
        </div>
        <button class="btn btn-success">Signup</button>
    </form>
    </div>
    </div>
    